generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  domain         String?  @unique
  logo           String?
  phone          String?
  address        String?
  primaryColor   String   @default("#000000")
  secondaryColor String   @default("#ffffff")
  plan           String   @default("starter")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  staff        Staff[]
  services     Service[]
  appointments Appointment[]
  schedules    Schedule[]
  owner        Owner?
}

model Staff {
  id         String  @id @default(cuid())
  businessId String
  name       String
  photo      String?
  active     Boolean @default(true)

  business     Business      @relation(fields: [businessId], references: [id])
  appointments Appointment[]
  schedules    Schedule[]
}

model Service {
  id         String  @id @default(cuid())
  businessId String
  name       String
  price      Float
  duration   Int
  active     Boolean @default(true)

  business     Business      @relation(fields: [businessId], references: [id])
  appointments Appointment[]
}

model Schedule {
  id         String  @id @default(cuid())
  businessId String
  staffId    String
  dayOfWeek  Int
  startTime  String
  endTime    String
  active     Boolean @default(true)

  business Business @relation(fields: [businessId], references: [id])
  staff    Staff    @relation(fields: [staffId], references: [id])
}

model Appointment {
  id          String   @id @default(cuid())
  businessId  String
  staffId     String
  serviceId   String
  clientName  String
  clientPhone String
  clientEmail String?
  date        DateTime
  status      String   @default("confirmed")
  source      String   @default("web")
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
  staff    Staff    @relation(fields: [staffId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
}

model Owner {
  id         String   @id @default(cuid())
  businessId String   @unique
  email      String   @unique
  password   String
  name       String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  parentSlug     String?
  locationSlug   String   @default("")
  domain         String?  @unique
  logo           String?
  phone          String?
  retellPhoneNumber String?  @unique
  address        String?
  primaryColor   String   @default("#000000")
  secondaryColor String   @default("#ffffff")
  plan           String   @default("starter")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  ownerId        String

  staff             Staff[]
  services          Service[]
  appointments      Appointment[]
  schedules         Schedule[]
  staffAssignments  StaffAssignment[] @relation("StaffAssignmentLocation")
  serviceLocations  ServiceLocation[] @relation("ServiceLocationLocation")
  owner             Owner             @relation(fields: [ownerId], references: [id])

  @@index([parentSlug])
}

model Staff {
  id         String  @id @default(cuid())
  businessId String
  name       String
  photo      String?
  active     Boolean @default(true)

  business         Business          @relation(fields: [businessId], references: [id])
  staffAssignments StaffAssignment[]
  appointments     Appointment[]
  schedules        Schedule[]
}

model Service {
  id         String  @id @default(cuid())
  businessId String
  name       String
  price      Float
  duration   Int
  active     Boolean @default(true)

  business         Business          @relation(fields: [businessId], references: [id])
  serviceLocations ServiceLocation[]
  appointments     Appointment[]
}

model StaffAssignment {
  id         String  @id @default(cuid())
  staffId    String
  businessId String
  active     Boolean @default(true)

  staff    Staff    @relation(fields: [staffId], references: [id])
  location Business @relation("StaffAssignmentLocation", fields: [businessId], references: [id])

  @@unique([staffId, businessId])
  @@index([businessId])
}

model ServiceLocation {
  id         String  @id @default(cuid())
  serviceId  String
  businessId String
  price      Float?
  active     Boolean @default(true)

  service  Service?  @relation(fields: [serviceId], references: [id])
  location Business @relation("ServiceLocationLocation", fields: [businessId], references: [id])

  @@unique([serviceId, businessId])
  @@index([businessId])
}

model Schedule {
  id         String  @id @default(cuid())
  businessId String
  staffId    String
  dayOfWeek  Int
  startTime  String
  endTime    String
  active     Boolean @default(true)

  business Business @relation(fields: [businessId], references: [id])
  staff    Staff    @relation(fields: [staffId], references: [id])
}

model Appointment {
  id          String   @id @default(cuid())
  businessId  String
  staffId     String
  serviceId   String?
  clientName  String
  clientPhone String
  clientEmail String?
  date        DateTime
  status      String   @default("confirmed")
  source      String   @default("web")
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
  staff    Staff    @relation(fields: [staffId], references: [id])
  service  Service?  @relation(fields: [serviceId], references: [id])
}

model Owner {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  businesses Business[]
}
